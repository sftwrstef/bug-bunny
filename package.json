{
  "name": "bug-bunny-ai",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=10"
  },
  "type": "module",
  "scripts": {
    "dev": "node server/dev.js",
    "api": ".venv/bin/python -m uvicorn backend.main:app --host 127.0.0.1 --port 8000",
    "api:web": "BUG_BUNNY_API_PORT=8787 node server/index.js",
    "web": "vite --host 127.0.0.1 --port 5173",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "prove:idor": "python3 -m proofs.idor_proof --output artifacts/idor-before.json",
    "fixture:replay:vulnerable": "python3 -m proofs.authenticated_replay_demo --mode vulnerable --port 8899",
    "fixture:replay:secure": "python3 -m proofs.authenticated_replay_demo --mode secure --port 8899",
    "demo:replay:record": "node scripts/record_authenticated_replay_demo.mjs",
    "demo:replay:render": ".venv/bin/python scripts/render_authenticated_replay_demo.py",
    "test:proof": ".venv/bin/python -m unittest discover -s tests -p 'test_*.py' -v",
    "test:web": "node --test tests/web_audit_test.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
